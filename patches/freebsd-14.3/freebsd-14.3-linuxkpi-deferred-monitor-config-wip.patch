+static void
+lkpi_hw_schedule_monitor(struct ieee80211_hw *hw, bool enable)
+{
+	struct lkpi_hw *lhw;
+
+	lhw = HW_TO_LHW(hw);
+
+	mtx_lock(&lhw->monitor_mtx);
+	lhw->monitor_desired = enable;
+	lhw->monitor_generation++;
+	mtx_unlock(&lhw->monitor_mtx);
+
+	taskqueue_enqueue(taskqueue_thread, &lhw->monitor_task);
+}
+
+static void
+lkpi_hw_monitor_task(void *ctx, int pending)
+{
+	struct ieee80211_hw *hw;
+	struct lkpi_hw *lhw;
+	uint32_t generation;
+	bool enable;
+	int error;
+
+	lhw = ctx;
+	hw = LHW_TO_HW(lhw);
+
+	for (;;) {
+		mtx_lock(&lhw->monitor_mtx);
+		enable = lhw->monitor_desired;
+		generation = lhw->monitor_generation;
+		mtx_unlock(&lhw->monitor_mtx);
+
+		/*
+		 * mt7921 monitor changes send MCU commands and may sleep.  Keep
+		 * this path out of lkpi_iv_newstate(), where net80211 holds the
+		 * com lock while Kismet/BPF is setting radiotap DLT state.
+		 */
+		error = lkpi_hw_set_monitor(hw, enable);
+		if (error != 0)
+			ic_printf(lhw->ic, "%s: monitor config returned %d\n",
+			    __func__, error);
+
+		mtx_lock(&lhw->monitor_mtx);
+		if (generation == lhw->monitor_generation) {
+			mtx_unlock(&lhw->monitor_mtx);
+			break;
+		}
+		mtx_unlock(&lhw->monitor_mtx);
+	}
+}

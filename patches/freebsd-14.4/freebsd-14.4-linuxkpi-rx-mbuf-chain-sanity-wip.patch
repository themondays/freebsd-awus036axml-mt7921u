+static bool
+lkpi_mbuf_rx_chain_sane(struct mbuf *m, int *pktlenp)
+{
+	struct mbuf *n;
+	int pktlen;
+
+	if (__predict_false(m == NULL || (m->m_flags & M_PKTHDR) == 0 ||
+	    m->m_pkthdr.len < sizeof(struct ieee80211_frame_ack)))
+		return (false);
+
+	pktlen = 0;
+	for (n = m; n != NULL; n = n->m_next) {
+		if (__predict_false(n->m_len < 0 ||
+		    n->m_len > m->m_pkthdr.len ||
+		    pktlen > m->m_pkthdr.len - n->m_len))
+			return (false);
+		pktlen += n->m_len;
+	}
+	if (pktlenp != NULL)
+		*pktlenp = pktlen;
+
+	return (pktlen == m->m_pkthdr.len);
+}

@@ -3643,6 +3647,32 @@ lkpi_iv_newstate(struct ieee80211vap *vap, enum ieee80211_state nstate, int arg)
 
 		s = sta_state_fsm;
 
+	} else if (vap->iv_opmode == IEEE80211_M_MONITOR) {
+
+		lhw = ic->ic_softc;
+		hw = LHW_TO_HW(lhw);
+		lvif = VAP_TO_LVIF(vap);
+
+		error = lvif->iv_newstate(vap, nstate, arg);
+		if (error != 0)
+			return (error);
+
+		if (nstate == IEEE80211_S_RUN) {
+			error = lkpi_hw_set_monitor(hw, true);
+		} else if (nstate == IEEE80211_S_INIT &&
+		    !lkpi_lhw_has_running_monitor_vif(lhw)) {
+			error = lkpi_hw_set_monitor(hw, false);
+		} else {
+			error = 0;
+		}
+		if (error != 0) {
+			ic_printf(vap->iv_ic, "%s: monitor config returned %d\n",
+			    __func__, error);
+			return (error);
+		}
+
+		return (0);
+
 	} else {
 		ic_printf(vap->iv_ic, "%s: only station mode currently supported: "
 		    "cap %p iv_opmode %d\n", __func__, vap, vap->iv_opmode);
@@ -3852,6 +3882,55 @@ lkpi_vif_iflladdr(void *arg, struct ifnet *ifp)
 	NET_EPOCH_EXIT(et);
 }
 
+static bool
+lkpi_ic_has_vap_opmode(struct ieee80211com *ic, enum ieee80211_opmode opmode)
+{
+	struct ieee80211vap *vap;
+
+	TAILQ_FOREACH(vap, &ic->ic_vaps, iv_next) {
+		if (vap->iv_opmode == opmode)
+			return (true);
+	}
+
+	return (false);
+}
+
+static bool
+lkpi_lhw_has_running_monitor_vif(struct lkpi_hw *lhw)
+{
+	struct lkpi_vif *lvif;
+
+	TAILQ_FOREACH(lvif, &lhw->lvif_head, lvif_entry) {
+		struct ieee80211vap *vap;
+
+		vap = LVIF_TO_VAP(lvif);
+		if (vap->iv_opmode == IEEE80211_M_MONITOR &&
+		    vap->iv_state != IEEE80211_S_INIT)
+			return (true);
+	}
+
+	return (false);
+}
+
+static int
+lkpi_hw_set_monitor(struct ieee80211_hw *hw, bool enable)
+{
+	bool monitor;
+	int error;
+
+	monitor = (hw->conf.flags & IEEE80211_CONF_MONITOR) != 0;
+	if (monitor == enable)
+		return (0);
+
+	if (enable)
+		hw->conf.flags |= IEEE80211_CONF_MONITOR;
+	else
+		hw->conf.flags &= ~IEEE80211_CONF_MONITOR;
+
+	error = lkpi_80211_mo_config(hw, IEEE80211_CONF_CHANGE_MONITOR);
+	return (error == EOPNOTSUPP ? 0 : error);
+}
